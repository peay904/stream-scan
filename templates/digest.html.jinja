<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Streaming Releases — {{ run_date }}</title>
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f0f0f;
      color: #e8e8e8;
      padding: 2rem;
    }

    /* ── Header ── */
    .header {
      text-align: center;
      padding: 3rem 0 2rem;
      border-bottom: 1px solid #333;
      margin-bottom: 3rem;
    }
    .header h1 {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #fff;
    }
    .header .subtitle {
      color: #888;
      margin-top: 0.5rem;
      font-size: 1rem;
    }
    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 1.5rem;
    }
    .stat { text-align: center; }
    .stat .num { font-size: 2rem; font-weight: 700; color: #e50914; }
    .stat .label { font-size: 0.8rem; color: #666; text-transform: uppercase; letter-spacing: 1px; }

    /* ── Section ── */
    .section-title {
      font-size: 1.5rem;
      font-weight: 600;
      margin: 2.5rem 0 1.5rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #e50914;
      color: #fff;
    }

    /* ── Service Badge ── */
    .service-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .svc-Netflix    { background: #e50914; color: #fff; }
    .svc-Hulu       { background: #1ce783; color: #000; }
    .svc-Prime      { background: #00a8e1; color: #fff; }
    .svc-Max        { background: #002be7; color: #fff; }
    .svc-Peacock    { background: #f5a623; color: #000; }
    .svc-Paramount  { background: #0064ff; color: #fff; }
    .svc-Apple      { background: #000;    color: #fff; }
    .svc-Disney     { background: #1e2161; color: #fff; }
    .svc-default    { background: #444;    color: #fff; }

    /* ── Card Grid ── */
    .grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
      gap: 1.5rem;
    }

    /* ── Card ── */
    .card {
      background: #1a1a1a;
      border-radius: 8px;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
      cursor: default;
    }
    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.6);
    }
    .card img {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      display: block;
      background: #2a2a2a;
    }
    .card .card-body {
      padding: 0.75rem;
    }
    .card .card-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 0.35rem;
      line-height: 1.3;
    }
    .card .card-meta {
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 0.5rem;
    }
    .card .card-overview {
      font-size: 0.78rem;
      color: #aaa;
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 4;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card .card-overview.expanded {
      display: block;
      -webkit-line-clamp: unset; /* This removes the 4-line limit */
    }    
    .card .card-tags {
      margin-top: 0.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }
    .expand-btn {
      display: block; /* Ensure it's not inline */
      width: fit-content;
      background: none;
      border: none;
      color: #e50914; /* Change to a brighter color like Netflix red to test visibility */
      font-size: 0.75rem;
      font-weight: bold;
      cursor: pointer;
      padding: 5px 0;
      text-decoration: none;
      margin-top: 4px;
    }
    .expand-btn:hover { color: #888; }
    .card .card-tags {
      margin-top: 0.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    /* ── No results ── */
    .empty {
      color: #555;
      font-style: italic;
      padding: 2rem 0;
      text-align: center;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid #222;
      color: #444;
      font-size: 0.8rem;
    }
  </style>
</head>
<body>

<div class="header">
  <h1>📺 New Streaming Releases</h1>
  <p class="subtitle">Content that premiered between {{ since_date }} and {{ run_date }}</p>
  <div class="stats-bar">
    <div class="stat">
      <div class="num">{{ total_count }}</div>
      <div class="label">Total New Titles</div>
    </div>
    <div class="stat">
      <div class="num">{{ movies|length }}</div>
      <div class="label">Movies</div>
    </div>
    <div class="stat">
      <div class="num">{{ shows|length }}</div>
      <div class="label">Shows</div>
    </div>
  </div>

{% macro service_class(svc) %}
{%- if "Netflix" in svc %}svc-Netflix
{%- elif "Hulu" in svc %}svc-Hulu
{%- elif "Prime" in svc or "Amazon" in svc %}svc-Prime
{%- elif "Max" in svc or "HBO" in svc %}svc-Max
{%- elif "Peacock" in svc %}svc-Peacock
{%- elif "Paramount" in svc %}svc-Paramount
{%- elif "Apple" in svc %}svc-Apple
{%- elif "Disney" in svc %}svc-Disney
{%- else %}svc-default
{%- endif %}
{% endmacro %}

{% macro media_card(item) %}
<div class="card">
  <img
    src="{{ item.poster_url or '' }}"
    alt="{{ item.title }} poster"
    loading="lazy"
    {# Note the change to single quotes inside the SVG below #}
    onerror="this.onerror=null; this.src='data:image/svg+xml,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'500\' height=\'750\'><rect fill=\'%23222\' width=\'100%\' height=\'100%\'/><text fill=\'%23555\' font-family=\'sans-serif\' font-size=\'40\' x=\'50%\' y=\'50%\' text-anchor=\'middle\' dy=\'.3em\'>No Image</text></svg>';"
  >
  <div class="card-body">
    <div class="card-title">{{ item.title }}</div>
    <div class="card-meta">
      {{ item.premiere_date }}
      {% if item.tmdb_rating > 0 %} · ⭐ {{ "%.1f"|format(item.tmdb_rating) }}{% endif %}
      {% if item.runtime_minutes > 0 %} · {{ item.runtime_minutes }}m{% endif %}
    </div>
    
    <div class="card-overview">{{ item.overview or "No summary available." }}</div>
    
    {# Only show button if overview is long enough to be clamped #}
    {% if item.overview and item.overview|length > 160 %}
      <button class="expand-btn" onclick="toggleOverview(this)">more</button>
    {% endif %}

    <div class="card-tags">
      {% for svc in item.services %}
      <span class="service-tag {{ service_class(svc) }}">{{ svc }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endmacro %}

<!-- Movies Section -->
<h2 class="section-title">🎬 New Movies ({{ movies|length }})</h2>
{% if movies %}
<div class="grid">
  {% for item in movies %}{{ media_card(item) }}{% endfor %}
</div>
{% else %}
<p class="empty">No new movies found for this period.</p>
{% endif %}

<!-- Shows Section -->
<h2 class="section-title">📺 New Shows ({{ shows|length }})</h2>
{% if shows %}
<div class="grid">
  {% for item in shows %}{{ media_card(item) }}{% endfor %}
</div>
{% else %}
<p class="empty">No new shows found for this period.</p>
{% endif %}

<!-- By Service Breakdown -->
<h2 class="section-title">By Streaming Service</h2>
{% for service, items in by_service.items() %}
<h3 style="margin: 1.5rem 0 1rem; color: #ccc; font-size: 1.1rem;">
  <span class="service-tag {{ service_class(service) }}">{{ service }}</span>
  <span style="color:#666; font-size:0.9rem; margin-left:0.5rem;">{{ items|length }} title{% if items|length != 1 %}s{% endif %}</span>
</h3>
<div class="grid">
  {% for item in items %}{{ media_card(item) }}{% endfor %}
</div>
{% endfor %}

<footer>
  Generated by Stream Scan · Data from Trakt.tv + TMDB · {{ run_date }}
</footer>

<script>
function toggleOverview(btn) {
  const overview = btn.previousElementSibling;
  const isExpanded = overview.classList.toggle('expanded');
  btn.textContent = isExpanded ? 'less' : 'more';
}
</script>

</body>
</html>
