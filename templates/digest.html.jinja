<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Streaming Releases — {{ run_date }}</title>
  {% if favicon_data %}
  <link rel="icon" type="image/svg+xml" href="data:image/svg+xml;base64,{{ favicon_data }}">
  {% endif %}
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f0f0f;
      color: #e8e8e8;
      overflow-x: hidden;
    }

    /* ── Header ── */
    .header {
      padding: 2rem 1.5rem 1.5rem;
      border-bottom: 2px solid #FBB13B;
      margin-bottom: 0;
    }

    .header-top {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-bottom: 1.25rem;
    }

    .header h1 {
      font-size: 1.8rem;
      font-weight: 800;
      letter-spacing: 1px;
      color: #fff;
      text-transform: uppercase;
    }

    .logo-right svg { height: 48px; width: auto; display: block; }

    .stats-bar { display: flex; gap: 2rem; }
    .stat .num   { font-size: 1.6rem; font-weight: 700; color: #FBB13B; line-height: 1; }
    .stat .label { font-size: 0.7rem; color: #666; text-transform: uppercase; letter-spacing: 0.5px; margin-top: 2px; }

    /* ── Service List ── */
    .service-list { padding: 0 1.5rem 3rem; }
    .service-section { border-bottom: 1px solid #1e1e1e; }

    .service-toggle {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      width: 100%;
      background: none;
      border: none;
      padding: 0.85rem 0;
      cursor: pointer;
      text-align: left;
      color: inherit;
    }

    .service-name { font-size: 1.1rem; font-weight: 700; color: #ccc; transition: color 0.15s; }
    .service-count { font-size: 0.8rem; color: #555; }
    .service-chevron { margin-left: auto; width: 16px; height: 16px; color: #555; transition: transform 0.25s ease; }
    
    .service-section.open .service-chevron { transform: rotate(180deg); color: #FBB13B; }
    .service-section.open .service-name { color: #fff; }

    .scroll-panel { display: grid; grid-template-rows: 0fr; transition: grid-template-rows 0.3s ease; }
    .service-section.open .scroll-panel { grid-template-rows: 1fr; }
    .scroll-panel-inner { overflow: hidden; }

    .scroll-row {
      display: flex;
      gap: 0.85rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      padding: 0.75rem 0 1rem;
      cursor: grab;
    }

    /* ── Badges ── */
    .service-tag {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 700;
      padding: 2px 0;
      width: 80px;
      text-align: center;
      border-radius: 3px;
      text-transform: uppercase;
    }

    /* Circular dots for the accordion list */
    .service-toggle .service-tag {
      width: 12px; height: 12px; padding: 0; border-radius: 50%;
      text-indent: -9999px; overflow: hidden; flex-shrink: 0;
    }

    .svc-Netflix   { background: #e50914; color: #fff; }
    .svc-Hulu      { background: #1ce783; color: #000; }
    .svc-Prime     { background: #00a8e1; color: #fff; }
    .svc-Max       { background: #002be7; color: #fff; }
    .svc-Peacock   { background: #f5a623; color: #000; }
    .svc-Paramount { background: #0064ff; color: #fff; }
    .svc-Apple     { background: #000;    color: #fff; border: 1px solid #444; }
    .svc-Disney    { background: #1e2161; color: #fff; }
    .svc-default   { background: #444;    color: #fff; }

    /* ── Card ── */
    .card { flex: 0 0 155px; scroll-snap-align: start; background: #1a1a1a; border-radius: 8px; overflow: hidden; }
    .card img { width: 100%; aspect-ratio: 2/3; object-fit: cover; background: #2a2a2a; }
    .card-body { padding: 0.65rem; }

    .card-type-badge {
      display: inline-block; font-size: 0.6rem; font-weight: 600; padding: 1px 5px;
      border-radius: 3px; background: #222; text-transform: uppercase; margin-bottom: 0.35rem;
    }
    .card-type-badge.movie { color: #FBB13B; }
    .card-type-badge.show  { color: #7ec8e3; }

    .card-title { font-size: 0.85rem; font-weight: 600; color: #fff; margin-bottom: 0.3rem; line-height: 1.3; }
    .card-meta { font-size: 0.7rem; color: #555; margin-bottom: 0.45rem; }
    
    .card-overview {
      position: relative; font-size: 0.75rem; color: #888; line-height: 1.5;
      max-height: 5.5em; overflow: hidden; transition: max-height 0.3s ease;
    }
    .card-overview.expanded { max-height: 600px; overflow: visible; }
    
    .card-overview:not(.expanded)::after {
      content: ""; position: absolute; bottom: 0; right: 0; width: 100%; height: 2em;
      background: linear-gradient(to bottom, rgba(26,26,26,0), #1a1a1a);
    }

    .expand-btn {
      display: block; background: none; border: none; color: #FBB13B;
      font-size: 0.7rem; font-weight: 700; cursor: pointer; padding: 4px 0;
    }

    /* ── Patify Button Hidden Logic ── */
    .patify-btn {
      display: none; /* Hidden by default */
      margin-top: 10px;
      padding: 5px 6px;
      background: #FBB13B;
      color: #000; /* Dark text for better contrast on yellow */
      border-radius: 4px;
      font-size: 0.68rem;
      font-weight: 700;
      text-align: center;
      text-decoration: none;
    }

    /* Show button only when the overview class has 'expanded' */
    .card-overview.expanded ~ .patify-btn {
      display: block;
    }

    footer { text-align: center; padding: 1.5rem; border-top: 1px solid #1e1e1e; color: #444; font-size: 0.75rem; }
    .footer-logo { display: flex; justify-content: center; margin-top: 1rem; opacity: 0.5; }

    @media (max-width: 480px) { .header h1 { font-size: 1.4rem; } .card { flex: 0 0 130px; } }
  </style>
</head>
<body>

<div class="header">
  <div class="header-top">
    <h1>New on Streaming</h1>
    <div class="logo-right">{{ svg2 | safe }}</div>
  </div>
  <div class="stats-bar">
    <div class="stat">
      <div class="num">{{ total_count }}</div>
      <div class="label">Total Titles</div>
    </div>
    <div class="stat">
      <div class="num">{{ movies|length }}</div>
      <div class="label">Movies</div>
    </div>
    <div class="stat">
      <div class="num">{{ shows|length }}</div>
      <div class="label">Shows</div>
    </div>
  </div>
</div>

{% macro service_class(svc) %}
{%- if "Netflix" in svc %}svc-Netflix
{%- elif "Hulu" in svc %}svc-Hulu
{%- elif "Prime" in svc or "Amazon" in svc %}svc-Prime
{%- elif "Max" in svc or "HBO" in svc %}svc-Max
{%- elif "Peacock" in svc %}svc-Peacock
{%- elif "Paramount" in svc %}svc-Paramount
{%- elif "Apple" in svc %}svc-Apple
{%- elif "Disney" in svc %}svc-Disney
{%- else %}svc-default
{%- endif %}
{% endmacro %}

{% macro media_card(item) %}
<div class="card">
  <img src="{{ item.poster_url or '' }}" alt="{{ item.title }}" loading="lazy" onerror="this.src='https://via.placeholder.com/155x230?text=No+Image';">
  <div class="card-body">
    <span class="card-type-badge {{ item.type }}">{{ item.type }}</span>
    <div class="card-title">{{ item.title }}</div>
    <div class="card-meta">
      {{ item.premiere_date | format_date }}
      {% if item.tmdb_rating > 0 %} · ⭐ {{ "%.1f"|format(item.tmdb_rating) }}{% endif %}
    </div>
    
    <div class="card-overview">{{ item.overview or "No summary available." }}</div>
    
    <button class="expand-btn" onclick="toggleOverview(this)">more</button>
    
    <a class="patify-btn" 
       href="https://mypatify.com/{{ 'movie' if item.type == 'movie' else 'tv' }}/{{ item.tmdb_id }}" 
       target="_blank" rel="noopener noreferrer">+ Add to Patify</a>
  </div>
</div>
{% endmacro %}

<div class="service-list">
  {% for service, items in by_service.items() %}
  <div class="service-section">
    <button class="service-toggle" onclick="toggleService(this)">
      <span class="service-tag {{ service_class(service) | trim }}">{{ service }}</span>
      <span class="service-name">{{ service }}</span>
      <span class="service-count">{{ items|length }} title{% if items|length != 1 %}s{% endif %}</span>
      <svg class="service-chevron" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
    </button>
    <div class="scroll-panel">
      <div class="scroll-panel-inner">
        <div class="scroll-row" data-drag-scroll>
          {% for item in items %}{{ media_card(item) }}{% endfor %}
        </div>
      </div>
    </div>
  </div>
  {% endfor %}
</div>

<footer>
  Generated by Patify Stream-Scan · {{ run_date }}
  <div class="footer-logo">{{ svg1 | safe }}</div>
</footer>

<script>
function toggleService(btn) {
  const section = btn.closest('.service-section');
  section.classList.toggle('open');
}

function toggleOverview(btn) {
  const overview = btn.previousElementSibling;
  
  // Close others
  document.querySelectorAll('.card-overview.expanded').forEach(el => {
    if (el !== overview) {
      el.classList.remove('expanded');
      el.nextElementSibling.textContent = 'more';
    }
  });

  const isExpanded = overview.classList.toggle('expanded');
  btn.textContent = isExpanded ? 'less' : 'more';
}

// Enable horizontal drag-to-scroll
document.addEventListener('DOMContentLoaded', () => {
  document.querySelectorAll('[data-drag-scroll]').forEach(row => {
    let isDown = false; let startX; let scrollLeft;
    row.addEventListener('mousedown', (e) => { isDown = true; startX = e.pageX - row.offsetLeft; scrollLeft = row.scrollLeft; });
    row.addEventListener('mouseleave', () => { isDown = false; });
    row.addEventListener('mouseup', () => { isDown = false; });
    row.addEventListener('mousemove', (e) => {
      if(!isDown) return;
      e.preventDefault();
      const x = e.pageX - row.offsetLeft;
      const walk = (x - startX) * 2;
      row.scrollLeft = scrollLeft - walk;
    });
  });
});
</script>

</body>
</html>