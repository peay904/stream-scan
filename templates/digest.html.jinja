<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>New Streaming Releases — {{ run_date }}</title>
  <style>
    /* ── Reset & Base ── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
      background: #0f0f0f;
      color: #e8e8e8;
      padding: 2rem;
      overflow-x: hidden;
    }

    /* ── Header ── */
    .header {
      padding: 3rem 0 2rem;
      border-bottom: 1px solid #333;
      margin-bottom: 3rem;
    }

    .header-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 1.5rem;
      max-width: 1300px;
      margin: 0 auto;
      padding: 0 20px;
    }

    .header-img {
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .logo-left  { width: 140px; }
    .logo-right { width: 170px; height: 60px; }

    .header-img svg {
      width: 100%;
      height: auto;
      display: block;
    }

    .header-center {
      flex: 1;
      text-align: center;
    }

    .header h1 {
      font-size: 2.5rem;
      font-weight: 700;
      letter-spacing: -0.5px;
      color: #fff;
      margin: 0;
    }

    .header .subtitle {
      color: #888;
      margin-top: 0.5rem;
      font-size: 1rem;
    }

    .stats-bar {
      display: flex;
      justify-content: center;
      gap: 2rem;
      margin-top: 1.5rem;
    }

    .stat { text-align: center; }
    .stat .num   { font-size: 2rem; font-weight: 700; color: #FBB13B; }
    .stat .label { font-size: 0.8rem; color: #666; text-transform: uppercase; letter-spacing: 1px; }

    /* ── Service Section ── */
    .service-section {
      margin-bottom: 3rem;
    }

    .service-header {
      display: flex;
      align-items: baseline;
      gap: 0.75rem;
      margin-bottom: 1rem;
      padding-bottom: 0.5rem;
      border-bottom: 2px solid #FBB13B;
    }

    .service-header-name {
      font-size: 1.4rem;
      font-weight: 700;
      color: #fff;
    }

    .service-header-count {
      font-size: 0.85rem;
      color: #666;
    }

    /* ── Scroll Row ── */
    .scroll-row {
      display: flex;
      gap: 1rem;
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      -webkit-overflow-scrolling: touch;
      padding-bottom: 0.75rem;
      cursor: grab;
      user-select: none;
    }

    .scroll-row:active { cursor: grabbing; }

    /* Hide scrollbar on Webkit but keep it functional */
    .scroll-row::-webkit-scrollbar { height: 4px; }
    .scroll-row::-webkit-scrollbar-track { background: #1a1a1a; border-radius: 2px; }
    .scroll-row::-webkit-scrollbar-thumb { background: #333; border-radius: 2px; }
    .scroll-row::-webkit-scrollbar-thumb:hover { background: #555; }

    /* ── Service Badge ── */
    .service-tag {
      display: inline-block;
      font-size: 0.7rem;
      font-weight: 700;
      padding: 2px 8px;
      border-radius: 3px;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }
    .svc-Netflix    { background: #e50914; color: #fff; }
    .svc-Hulu       { background: #1ce783; color: #000; }
    .svc-Prime      { background: #00a8e1; color: #fff; }
    .svc-Max        { background: #002be7; color: #fff; }
    .svc-Peacock    { background: #f5a623; color: #000; }
    .svc-Paramount  { background: #0064ff; color: #fff; }
    .svc-Apple      { background: #000;    color: #fff; border: 1px solid #444; }
    .svc-Disney     { background: #1e2161; color: #fff; }
    .svc-default    { background: #444;    color: #fff; }

    /* ── Card ── */
    .card {
      flex: 0 0 170px;
      scroll-snap-align: start;
      background: #1a1a1a;
      border-radius: 8px;
      overflow: hidden;
      transition: transform 0.2s, box-shadow 0.2s;
    }
    .card:hover {
      transform: translateY(-4px);
      box-shadow: 0 12px 32px rgba(0,0,0,0.6);
    }
    .card img {
      width: 100%;
      aspect-ratio: 2/3;
      object-fit: cover;
      display: block;
      background: #2a2a2a;
      pointer-events: none;
    }
    .card .card-body  { padding: 0.75rem; }
    .card .card-title {
      font-size: 0.9rem;
      font-weight: 600;
      color: #fff;
      margin-bottom: 0.35rem;
      line-height: 1.3;
    }
    .card .card-meta {
      font-size: 0.75rem;
      color: #666;
      margin-bottom: 0.5rem;
    }
    .card .card-type-badge {
      display: inline-block;
      font-size: 0.65rem;
      font-weight: 600;
      padding: 1px 6px;
      border-radius: 3px;
      background: #2a2a2a;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.4rem;
    }
    .card .card-type-badge.movie { color: #FBB13B; }
    .card .card-type-badge.show  { color: #7ec8e3; }

    .card .card-overview {
      position: relative;
      font-size: 0.78rem;
      color: #aaa;
      line-height: 1.5;
      max-height: 6em;
      overflow: hidden;
      transition: max-height 0.3s ease;
    }
    .card-overview.expanded {
      max-height: 600px;
      overflow: visible;
    }
    .card-overview:not(.expanded)::after {
      content: "";
      position: absolute;
      bottom: 0;
      right: 0;
      width: 100%;
      height: 2em;
      background: linear-gradient(to bottom, rgba(26,26,26,0), #1a1a1a);
      pointer-events: none;
    }
    .card-overview.expanded::after { display: none; }

    .expand-btn {
      display: block;
      width: fit-content;
      background: none;
      border: none;
      color: #FBB13B;
      font-size: 0.75rem;
      font-weight: bold;
      cursor: pointer;
      padding: 5px 0;
      text-decoration: none;
      margin-top: 4px;
    }
    .expand-btn:hover { color: #888; }

    .card .card-tags {
      margin-top: 0.5rem;
      display: flex;
      flex-wrap: wrap;
      gap: 4px;
    }

    /* ── No results ── */
    .empty {
      color: #555;
      font-style: italic;
      padding: 2rem 0;
    }

    /* ── Footer ── */
    footer {
      text-align: center;
      margin-top: 4rem;
      padding-top: 1.5rem;
      border-top: 1px solid #222;
      color: #444;
      font-size: 0.8rem;
    }

    /* ── Mobile ── */
    @media (max-width: 600px) and (orientation: portrait) {
      .logo-left, .logo-right { display: none; }

      .header-center {
        padding: 1.5rem 0;
        margin-bottom: 1.5rem;
      }

      .header h1         { font-size: 1.6rem; }
      .header .subtitle  { font-size: 0.85rem; margin-bottom: 1rem; }

      .stats-bar {
        gap: 0.5rem;
        justify-content: space-between;
      }
      .stat .num   { font-size: 1.2rem; }
      .stat .label { font-size: 0.6rem; letter-spacing: 0; }

      .card { flex: 0 0 140px; }

      .footer-logo {
        display: flex;
        justify-content: center;
        margin-top: 1.5rem;
        opacity: 0.6;
      }
      .footer-logo svg { width: 120px; height: auto; }
    }
  </style>
</head>
<body>

<div class="header">
  <div class="header-inner">
    <div class="header-img logo-left">{{ svg1 | safe }}</div>
    <div class="header-center">
      <h1>📺 New Streaming Releases</h1>
      <p class="subtitle">Content that premiered between {{ since_date }} and {{ run_date }}</p>
      <div class="stats-bar">
        <div class="stat">
          <div class="num">{{ total_count }}</div>
          <div class="label">Total New Titles</div>
        </div>
        <div class="stat">
          <div class="num">{{ movies|length }}</div>
          <div class="label">Movies</div>
        </div>
        <div class="stat">
          <div class="num">{{ shows|length }}</div>
          <div class="label">Shows</div>
        </div>
        <div class="stat">
          <div class="num">{{ by_service|length }}</div>
          <div class="label">Services</div>
        </div>
      </div>
    </div>
    <div class="header-img logo-right">{{ svg2 | safe }}</div>
  </div>
</div>

{% macro service_class(svc) %}
{%- if "Netflix" in svc %}svc-Netflix
{%- elif "Hulu" in svc %}svc-Hulu
{%- elif "Prime" in svc or "Amazon" in svc %}svc-Prime
{%- elif "Max" in svc or "HBO" in svc %}svc-Max
{%- elif "Peacock" in svc %}svc-Peacock
{%- elif "Paramount" in svc %}svc-Paramount
{%- elif "Apple" in svc %}svc-Apple
{%- elif "Disney" in svc %}svc-Disney
{%- else %}svc-default
{%- endif %}
{% endmacro %}

{% macro media_card(item) %}
<div class="card">
  <img
    src="{{ item.poster_url or '' }}"
    alt="{{ item.title }} poster"
    loading="lazy"
    onerror="this.onerror=null; this.src='data:image/svg+xml,<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'500\' height=\'750\'><rect fill=\'%23222\' width=\'100%\' height=\'100%\'/><text fill=\'%23555\' font-family=\'sans-serif\' font-size=\'40\' x=\'50%\' y=\'50%\' text-anchor=\'middle\' dy=\'.3em\'>No Image</text></svg>';"
  >
  <div class="card-body">
    <span class="card-type-badge {{ item.type }}">{{ item.type }}</span>
    <div class="card-title">{{ item.title }}</div>
    <div class="card-meta">
      {{ item.premiere_date | format_date }}
      {% if item.tmdb_rating > 0 %} · ⭐ {{ "%.1f"|format(item.tmdb_rating) }}{% endif %}
      {% if item.runtime_minutes > 0 %} · {{ item.runtime_minutes }}m{% endif %}
    </div>

    <div class="card-overview">{{ item.overview or "No summary available." }}</div>
    <button class="expand-btn" onclick="toggleOverview(this)">more</button>

    <div class="card-tags">
      {% for svc in item.services %}
      <span class="service-tag {{ service_class(svc) }}">{{ svc }}</span>
      {% endfor %}
    </div>
  </div>
</div>
{% endmacro %}

<!-- Per-Service Horizontal Scroll Rows -->
{% for service, items in by_service.items() %}
<div class="service-section" id="svc-{{ service | lower | replace(' ', '-') | replace('+', 'plus') }}">
  <div class="service-header">
    <span class="service-tag {{ service_class(service) | trim }}">{{ service }}</span>
    <span class="service-header-name">{{ service }}</span>
    <span class="service-header-count">{{ items|length }} title{% if items|length != 1 %}s{% endif %}</span>
  </div>
  {% if items %}
  <div class="scroll-row" data-drag-scroll>
    {% for item in items %}{{ media_card(item) }}{% endfor %}
  </div>
  {% else %}
  <p class="empty">No new titles found for this period.</p>
  {% endif %}
</div>
{% endfor %}

<footer>
  Generated by Stream Scan · Data from Trakt.tv + TMDB · {{ run_date }}
  <div class="footer-logo">
    {{ svg2 | safe }}
  </div>
</footer>

<script>
// Hide "more" button when content isn't actually clipped
document.addEventListener('DOMContentLoaded', function () {
  document.querySelectorAll('.card-overview').forEach(function (el) {
    const btn = el.nextElementSibling;
    if (!btn || !btn.classList.contains('expand-btn')) return;
    if (el.scrollHeight <= el.clientHeight + 2) btn.style.display = 'none';
  });

  // Drag-to-scroll on desktop
  document.querySelectorAll('[data-drag-scroll]').forEach(function (row) {
    let isDragging = false, startX = 0, scrollStart = 0;

    row.addEventListener('mousedown', function (e) {
      isDragging = true;
      startX = e.pageX - row.offsetLeft;
      scrollStart = row.scrollLeft;
      row.style.cursor = 'grabbing';
    });

    document.addEventListener('mousemove', function (e) {
      if (!isDragging) return;
      e.preventDefault();
      const x = e.pageX - row.offsetLeft;
      row.scrollLeft = scrollStart - (x - startX);
    });

    document.addEventListener('mouseup', function () {
      isDragging = false;
      row.style.cursor = 'grab';
    });

    row.addEventListener('mouseleave', function () {
      isDragging = false;
      row.style.cursor = 'grab';
    });
  });
});

function toggleOverview(btn) {
  const overview = btn.previousElementSibling;

  document.querySelectorAll('.card-overview.expanded').forEach(function (el) {
    if (el !== overview) {
      el.classList.remove('expanded');
      if (el.nextElementSibling) el.nextElementSibling.textContent = 'more';
    }
  });

  const isExpanded = overview.classList.toggle('expanded');
  btn.textContent = isExpanded ? 'less' : 'more';
}
</script>

</body>
</html>
